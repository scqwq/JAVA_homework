# 优先读取 DATABASE_DSN，其次兼容旧字段 PGDSN / MYSQL_DSN
#
# DSN 是数据库连接字符串（Data Source Name），格式示例：
# PostgreSQL:
# DATABASE_DSN=jdbc:postgresql://127.0.0.1:5432/dormitory?user=postgres&password=123456
#
# MySQL:
# DATABASE_DSN=jdbc:mysql://127.0.0.1:3306/dormitory?user=root&password=123456&useSSL=false&serverTimezone=Asia/Shanghai
#
# 说明：
# 1. jdbc:postgresql / jdbc:mysql 表示数据库类型
# 2. 127.0.0.1:端口 表示数据库地址
# 3. /dormitory 表示数据库名
# 4. user / password 是登录账号密码
#
# 主外键关系：
# buildings.building_id           -> 宿舍楼主键
# rooms.room_id                   -> 宿舍房间主键
# rooms.building_id               -> 外键，指向 buildings.building_id
# students.student_id             -> 学生主键（学号）
# dorm_assignments.assignment_id  -> 住宿分配主键
# dorm_assignments.student_id     -> 外键，指向 students.student_id
# dorm_assignments.building_id    -> 外键，指向 buildings.building_id
# dorm_assignments.room_id        -> 外键，指向 rooms.room_id
#
# 每个 room 固定只有 4 个床位，床号 1-4。

APP_PORT=8080
DATABASE_DSN=
PGDSN = DATABASE_DSN=jdbc:postgresql://127.0.0.1:5432/JAVA?user=postgres&password=123456

MYSQL_DSN=
